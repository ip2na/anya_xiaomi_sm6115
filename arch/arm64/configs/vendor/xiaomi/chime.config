# IR Blaster
CONFIG_IR_SPI=y
CONFIG_LIRC=y
CONFIG_RC_CORE=y
CONFIG_RC_DECODERS=y
CONFIG_RC_DEVICES=y

# Touchscreen
CONFIG_TOUCHSCREEN_NT36672A=y
CONFIG_TOUCHSCREEN_FT8719=y
CONFIG_TOUCHSCREEN_XIAOMI_TOUCHFEATURE=y
# CONFIG_TOUCHSCREEN_FTS is not set
# CONFIG_TOUCHSCREEN_NT36XXX is not set

# Kernel Behavior
CONFIG_PANIC_ON_REFCOUNT_ERROR=n

# MSM Debugging
CONFIG_MSM_RDBG=y

# NFC
# CONFIG_NFC_NQ is not set

# Platform
CONFIG_BOARD_XIAOMI=y
CONFIG_BOARD_XIAOMI_SM6115=y

# Switch
CONFIG_SWITCH=y

# WLAN
CONFIG_QCA_CLD_WLAN=y

# Xiaomi Specific Drivers
CONFIG_SIMTRAY_STATUS=y
CONFIG_DPDT_STATUS=y
CONFIG_MI_FS=y
CONFIG_HQ_SYSFS_SUPPORT=y